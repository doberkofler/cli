	"bin": "./dist/index.js",
	"type": "module",
	"scripts": {
		"lint": "tsc && oxlint --disable-nested-config src client server tests *.config.ts && pnpm run format:check",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"test": "vitest run --coverage",
		"release": "release-it",
		"ci": "pnpm run lint && pnpm run build && pnpm run test",
		"create-changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
		"prepare": "husky",
		"dev": "vite build --watch",
		"build": "vite build",
		"integration-test": "node -e \"\""
	},
	"dependencies": {
		"cli-progress": "3.12.0",
		"commander": "14.0.3",
		"debug": "4.4.3",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@commitlint/cli": "20.5.0",
		"@commitlint/config-conventional": "20.5.0",
		"@types/cli-progress": "3.11.6",
		"@types/debug": "4.1.13",
		"@types/node": "25.5.0",
		"@vitest/coverage-v8": "4.1.1",
		"conventional-changelog": "7.2.0",
		"eslint-plugin-regexp": "3.1.0",
